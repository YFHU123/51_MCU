  19          /* 定时器0初始化函数 */
  20          void Timer0_Init(void) // 1毫秒@12.000MHz
  21          {
  22   1          TMOD &= 0xF0; // 设置定时器模式
  23   1          TMOD |= 0x01; // 设置定时器模式
  24   1          TL0 = 0x18;   // 设置定时初始值
  25   1          TH0 = 0xFC;   // 设置定时初始值
  26   1          TF0 = 0;      // 清除TF0标志
  27   1          TR0 = 1;      // 定时器0开始计时
