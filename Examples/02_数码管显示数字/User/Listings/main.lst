  32          /* 定时器0中断服务函数 */
  33          void Timer0Sever() interrupt 1
  34          {
  35   1          TL0 = 0x18; // 设置定时初始值
  36   1          TH0 = 0xFC; // 设置定时初始值
  37   1      
  38   1          if (++Seg_Slow_Down == 200)
