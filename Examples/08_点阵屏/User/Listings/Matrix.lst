 137   1          // ShiftByte(0xFF); ShiftByte(0xFF); // 行熄灭
 138   1          // ShiftByte(0x00); ShiftByte(0x00); // 列断电
 139   1          // RCK = 1; RCK = 0;
 140   1      }
