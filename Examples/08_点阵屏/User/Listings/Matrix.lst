 142          void Matrix16x16_Scrolling(unsigned char *pArray, unsigned int TotalLen, unsigned char Speed)
 143          {
 144   1          static unsigned int ScrollOffset = 0; // 改为 int，防止多字滚动时超过 255
 145   1          static unsigned char SpeedCount = 0;   
 146   1          unsigned char i;
 147   1          unsigned int rowindex;
 148   1      
 149   1          for(i = 0; i < 16; i++)
 150   1          {
 151   2              // 关键：TotalLen / 2 是总行数（两个字就是 32 行）
 152   2              // 这里计算的是：当前显示的第 i 行，对应整个长数组中的哪一行
 153   2              rowindex = (i + ScrollOffset) % (TotalLen / 2);
 154   2              
 155   2              // 每一行取两个连续字节：rowindex*2 是左字节，rowindex*2+1 是右字节
 156   2              Matrix16x16_ShowColumn(i, pArray[rowindex * 2], pArray[rowindex * 2 + 1]);
 157   2          }
 158   1      
 159   1          SpeedCount++;
 160   1          if(SpeedCount > Speed)
 161   1          {
 162   2              SpeedCount = 0;
 163   2              ScrollOffset++; 
 164   2              
 165   2              if(ScrollOffset >= (TotalLen / 2)) 
 166   2              {
 167   3                  ScrollOffset = 0; 
 168   3              }
 169   2          }
 170   1      }


