 105          /**
 106            * @brief 16x16 点阵显示核心函数（自动修正左右反置与镜像）
 107            * @param Column 扫描行号 (0-15)
 108            * @param DataL  左半部分数据字节
 109            * @param DataH  右半部分数据字节
 110            */
 111          void Matrix16x16_ShowColumn(unsigned char Column, unsigned char DataL, unsigned char DataH) 
 112          {
 113   1          unsigned int RowSelect = ~(0x0001 << Column); 
 114   1          unsigned char i, tempL = 0, tempH = 0;
 115   1      
 116   1          // 将取模软件的高位在前转为低位在前，匹配 595 输出顺序
C51 COMPILER V9.60.7.0   MATRIX                                                            03/16/2026 17:41:44 PAGE 3   

 117   1          for(i = 0; i < 8; i++) {
 118   2              if(DataL & (0x01 << i)) tempL |= (0x80 >> i);
 119   2              if(DataH & (0x01 << i)) tempH |= (0x80 >> i);
 120   2          }
 121   1      
 122   1          // 1. 发送行选高字节 (挤到 U5)
 123   1          ShiftByte((unsigned char)(RowSelect >> 8));   
 124   1          
 125   1          // 2. 发送行选低字节 (挤到 U4)
 126   1          ShiftByte((unsigned char)(RowSelect & 0xFF)); 
 127   1      
 128   1          // 3. 先发右半边数据 (挤到 U3)
 129   1          ShiftByte(tempH); 
 130   1      
 131   1          // 4. 后发左半边数据 (留在 U2)
 132   1          ShiftByte(tempL); 
 133   1      
 134   1          RCK = 1; RCK = 0; // 锁存显示
 135   1      
