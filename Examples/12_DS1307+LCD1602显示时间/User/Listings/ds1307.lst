  42          /* DS1307 读写封装 */
  43          void Write_Ds1307_Byte(unsigned char addr, unsigned char dat) {
  44   1          IIC_Start();
  45   1          IIC_SendByte(0xD0); // DS1307 写地址
  46   1          IIC_SendByte(addr); 
