  20          void IIC_SendByte(unsigned char dat) {
  21   1          unsigned char i;
  22   1          for(i=0; i<8; i++) {
  23   2              SDA = dat >> 7; // IIC 高位在前
  24   2              dat <<= 1;
  25   2              SCL = 1; _nop_(); SCL = 0;
  26   2          }
  27   1          SDA = 1; SCL = 1; _nop_(); SCL = 0; // 释放 SDA 等待应答
  28   1      }
  29          
  30          unsigned char IIC_RecvByte() {
  31   1          unsigned char i, dat = 0;
  32   1          SDA = 1; 
  33   1          for(i=0; i<8; i++) {
  34   2              SCL = 1; _nop_();
  35   2              dat <<= 1;
  36   2              if(SDA) dat |= 0x01;
  37   2              SCL = 0;
  38   2          }
  39   1          return dat;
  40   1      }
