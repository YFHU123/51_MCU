  29          
  30          void write_byte(unsigned char dat)
  31          {
  32   1          unsigned char i;
  33   1          for(i=0; i<8; i++)
  34   1          {
  35   2              EA = 0;
  36   2              DS = 0;
  37   2              _nop_();
  38   2              DS = dat & 0x01;
  39   2              Delay_us(10);
  40   2              DS = 1; 
  41   2              EA = 1;
  42   2              dat >>= 1;
  43   2          }
  44   1      }
